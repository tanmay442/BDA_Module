# ============================================================
# Server
# ============================================================
PORT=5000
NODE_ENV=development

# ============================================================
# Database (MongoDB Atlas)
# ============================================================
# Inherit from process.env on Vercel; local dev uses backend/.env
MONGO_URI=

# ============================================================
# Clerk Authentication
# ============================================================
# Server SDK key (sk_test_... / sk_live_...). NEVER expose to the client.
CLERK_SECRET_KEY=

# Publishable key (pk_test_... / pk_live_...). Safe to expose.
# Also referenced as VITE_CLERK_PUBLISHABLE_KEY in the frontend.
CLERK_PUBLISHABLE_KEY=

# Svix signing secret for the Clerk webhook endpoint.
# Get it from: Clerk dashboard → Webhooks -> your endpoint -> Signing Secret
CLERK_WEBHOOK_SECRET=

# ============================================================
# Bootstrap
# ============================================================
# Comma-separated list of emails that should be auto-promoted to admin
# the FIRST time they sign in, IF the database has no admin rows yet.
# After the first admin exists, this list is ignored.
# Example: BOOTSTRAP_ADMIN_EMAILS=you@gmail.com,partner@gmail.com
BOOTSTRAP_ADMIN_EMAILS=

# ============================================================
# CORS (backend only - same-origin in production, dev allowlist below)
# ============================================================
# Comma-separated list of allowed origins for the Express API.
# In production (Vercel) the frontend and API share an origin, so CORS
# is a no-op; this list is consulted in development only.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Pusher (real-time broadcasts)
# ============================================================
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2
