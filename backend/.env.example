# Backend dev template. Copy to backend/.env.
# Real production values live in the Vercel project settings.

PORT=5000
NODE_ENV=development

# Database
MONGO_URI=

# Clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Pusher
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap2

# Bootstrap (comma-separated emails to auto-promote on first sign-in)
BOOTSTRAP_ADMIN_EMAILS=

# CORS (dev only)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
