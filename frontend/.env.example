# Frontend env (Vite reads VITE_-prefixed vars)
# Copy to frontend/.env and fill in real values for local dev.
# In production, these are set in the Vercel project settings.

# Clerk publishable key (pk_test_... / pk_live_...). Safe to expose.
VITE_CLERK_PUBLISHABLE_KEY=

# Pusher client config (subscribe-only key, safe to expose)
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=ap2
