# Frontend env (Vite reads VITE_-prefixed vars)
# Copy to frontend/.env and fill in real values for local dev.
# In production (Vercel), these are set in the Vercel project
# settings, NOT in a frontend/.env file. The empty values below
# are placeholders for the Vercel UI.

# Optional: where the API lives. In production (Vercel) the
# frontend and API share the same origin, so leave this empty
# to use the default '/api'. In local dev, point it at
# http://localhost:5000/api.
VITE_API_BASE_URL=

# Clerk publishable key (pk_test_... / pk_live_...). Safe to expose.
VITE_CLERK_PUBLISHABLE_KEY=

# Pusher client config (subscribe-only key, safe to expose).
# Leave VITE_PUSHER_KEY empty in environments where real-time
# updates aren't needed; the frontend will skip the Pusher
# connection entirely when this is unset.
VITE_PUSHER_KEY=
VITE_PUSHER_CLUSTER=ap2

# Optional: default company name pre-filled on the onboarding form.
# Multi-tenant deploys set this so new users see their own brand
# instead of a hard-coded "ACME Manufacturing". Leave empty to
# use the built-in fallback in OnboardingPage.jsx.
VITE_COMPANY_NAME=
